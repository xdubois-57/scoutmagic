{% extends "base.html.twig" %}

{% block title %}Réinitialiser le mot de passe — {{ site_name }}{% endblock %}

{% block content %}
<div class="page-narrow">
    <h1 class="mb-4 text-center">Réinitialiser le mot de passe</h1>

    {% if not valid %}
        <div class="card">
            <div class="card-body text-center py-4">
                <p class="text-danger mb-3">Ce lien de réinitialisation n'est plus valide (expiré, déjà utilisé, ou incorrect).</p>
                <a href="/login" class="btn btn-outline-secondary">Retour à la connexion</a>
            </div>
        </div>
    {% else %}
        <div class="card">
            <div class="card-body">
                <form method="post" action="/password-reset/{{ reset_id }}" id="reset-form">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="token" value="{{ reset_token }}">
                    <div class="mb-3">
                        <label class="form-label">Nouveau mot de passe</label>
                        <input type="password" name="new_password" class="form-control" id="reset-new-password" required autocomplete="new-password">
                    </div>
                    <div class="mb-3">
                        {% include 'partials/password_complexity_checklist.html.twig' with {list_id: 'reset-checklist'} %}
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirmer le nouveau mot de passe</label>
                        <input type="password" name="confirm_password" class="form-control" id="reset-confirm-password" required autocomplete="new-password">
                    </div>
                    <div class="text-danger small mb-2 d-none" id="reset-mismatch-error">Les mots de passe ne correspondent pas.</div>
                    <button type="submit" class="btn btn-primary w-100" id="reset-submit-btn">Réinitialiser le mot de passe</button>
                </form>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
{% if valid %}
<script src="/assets/js/password-complexity.js" nonce="{{ csp_nonce }}"></script>
<script nonce="{{ csp_nonce }}">
(function () {
    var checklist = initPasswordComplexityChecklist('reset-new-password', 'reset-checklist');
    var form = document.getElementById('reset-form');
    var confirmInput = document.getElementById('reset-confirm-password');
    var mismatchError = document.getElementById('reset-mismatch-error');

    form.addEventListener('submit', function (e) {
        mismatchError.classList.add('d-none');
        if (checklist && !checklist.isValid()) {
            e.preventDefault();
            return;
        }
        if (document.getElementById('reset-new-password').value !== confirmInput.value) {
            e.preventDefault();
            mismatchError.classList.remove('d-none');
        }
    });
})();
</script>
{% endif %}
{% endblock %}
