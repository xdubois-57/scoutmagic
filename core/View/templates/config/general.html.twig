{% extends "base.html.twig" %}

{% block title %}Configuration générale — {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="mb-4">Configuration générale</h1>

    {# Config mode section #}
    <div class="card mb-4">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <h2 class="h5 mb-1">Mode configuration</h2>
                <p class="text-body-secondary small mb-0">
                    Permet d'éditer les textes et les images du site pour cette session.
                </p>
            </div>
            <form method="post" action="/config-mode/{{ config_mode ? 'deactivate' : 'activate' }}">
                {{ csrf_field() }}
                <button type="submit" class="btn btn-sm {{ config_mode ? 'btn-warning' : 'btn-outline-primary' }}">
                    {{ config_mode ? 'Désactiver' : 'Activer' }}
                </button>
            </form>
        </div>
    </div>

    {# Modules section #}
    <h2 class="h5 mb-3">
        <i class="bi bi-puzzle text-body-secondary"></i> Modules
    </h2>
    <p class="text-body-secondary small mb-3">
        Activez ou désactivez les fonctionnalités du site.
        Les pages et paramètres d'un module n'apparaissent que lorsqu'il est actif.
    </p>

    <div class="d-flex flex-column gap-2" id="module-list">
        {% for mod in modules %}
            <div class="border rounded-3 p-3">
                <div class="d-flex align-items-start justify-content-between gap-3">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="fw-semibold">{{ mod.manifest.name }}</span>
                            {% if mod.enabled %}
                                <span class="badge bg-success-subtle text-success-emphasis">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Inactif</span>
                            {% endif %}
                            <span class="text-body-tertiary" style="font-size:0.75rem;">
                                v{{ mod.manifest.version }}
                            </span>
                            {% if mod.validationError %}
                                <span class="badge bg-danger-subtle text-danger-emphasis"
                                      title="{{ mod.validationError }}">Erreur</span>
                            {% endif %}
                            {% if not mod.presentOnDisk %}
                                <span class="badge bg-warning-subtle text-warning-emphasis">Manquant</span>
                            {% endif %}
                        </div>
                    </div>
                    {% if mod.presentOnDisk and not mod.validationError %}
                        <div class="form-check form-switch">
                            <input class="form-check-input module-toggle"
                                   type="checkbox" data-module="{{ mod.manifest.id }}"
                                   {{ mod.enabled ? 'checked' : '' }}>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}

        {% if modules is empty %}
            <p class="text-body-secondary fst-italic">
                Aucun module disponible. Placez des modules dans le répertoire
                <code>modules/</code> pour les voir apparaître ici.
            </p>
        {% endif %}
    </div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}">
document.querySelectorAll('.module-toggle').forEach(toggle => {
    toggle.addEventListener('change', async () => {
        const moduleId = toggle.dataset.module;
        const enabled = toggle.checked;
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
        const res = await fetch('/config/general/module-toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ module_id: moduleId, enabled, _csrf_token: csrf })
        });
        const data = await res.json();
        if (!data.success) {
            alert(data.error);
            toggle.checked = !enabled;
        } else {
            window.location.reload();
        }
    });
});
</script>
{% endblock %}
