{% extends "base.html.twig" %}

{% block title %}Configuration générale — {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="mb-4">Configuration générale</h1>

    {# Config mode section #}
    <div class="card mb-4">
        <div class="card-body d-flex align-items-center justify-content-between">
            <div>
                <h2 class="h5 mb-1">Mode configuration</h2>
                <p class="text-body-secondary small mb-0">
                    Permet d'éditer les textes et les images du site pour cette session.
                </p>
            </div>
            <form method="post" action="/config-mode/{{ config_mode ? 'deactivate' : 'activate' }}">
                {{ csrf_field() }}
                <button type="submit" class="btn btn-sm {{ config_mode ? 'btn-warning' : 'btn-outline-primary' }}">
                    {{ config_mode ? 'Désactiver' : 'Activer' }}
                </button>
            </form>
        </div>
    </div>

    {# Badges section #}
    <h2 class="h5 mb-3">
        <i class="bi bi-award text-body-secondary"></i> Badges
    </h2>
    <p class="text-body-secondary small mb-3">
        Rôles transversaux assignables aux chefs et chefs d'unité (ex: Infirmier, Trésorier),
        affichés sur le trombinoscope. Les badges par défaut ne peuvent pas être renommés ni
        supprimés, seulement désactivés.
    </p>

    <div class="d-flex flex-column gap-2 mb-3" id="badge-list">
        {% for badge in badges %}
            <div class="border rounded-3 p-3 d-flex align-items-center gap-3 badge-row" data-id="{{ badge.id }}" data-default="{{ badge.isDefault ? '1' : '0' }}">
                <input type="text" class="form-control form-control-sm badge-name-input" style="max-width:220px;" value="{{ badge.name }}" {{ badge.isDefault ? 'readonly' : '' }}>
                {% if badge.isDefault %}
                    <span class="badge bg-secondary-subtle text-secondary-emphasis">Par défaut</span>
                {% endif %}
                <div class="form-check form-switch ms-auto text-nowrap">
                    <input type="checkbox" class="form-check-input badge-active-input" role="switch" {{ badge.isActive ? 'checked' : '' }}>
                    <label class="form-check-label small">Actif</label>
                </div>
                {% if not badge.isDefault %}
                    {% set badgeIsAssigned = badge.id in assigned_badge_ids %}
                    {% if badgeIsAssigned %}
                        {# A disabled <button> doesn't fire the hover events browsers
                           need to show its own title tooltip, so the tooltip goes on
                           a plain (non-disabled) wrapping span instead; pointer-events:
                           none on the button lets the span receive the hover. #}
                        <span class="d-inline-block" title="Ce badge est attribué à un membre — désactivez-le au lieu de le supprimer.">
                            <button type="button" class="btn btn-sm btn-outline-danger badge-delete-btn" disabled style="pointer-events:none;">
                                <i class="bi bi-trash"></i>
                            </button>
                        </span>
                    {% else %}
                        <button type="button" class="btn btn-sm btn-outline-danger badge-delete-btn" title="Supprimer">
                            <i class="bi bi-trash"></i>
                        </button>
                    {% endif %}
                {% endif %}
            </div>
        {% endfor %}
    </div>

    <div class="border rounded-3 p-3 d-flex align-items-center gap-2 mb-4" id="badge-add-form">
        <input type="text" class="form-control form-control-sm" id="new-badge-name" placeholder="Communication" style="max-width:220px;">
        <button type="button" class="btn btn-sm btn-primary" id="badge-add-btn">
            <i class="bi bi-plus-lg"></i> Ajouter
        </button>
    </div>

    <hr class="my-4">

    {# Modules section #}
    <h2 class="h5 mb-3">
        <i class="bi bi-puzzle text-body-secondary"></i> Modules
    </h2>
    <p class="text-body-secondary small mb-3">
        Activez ou désactivez les fonctionnalités du site.
        Les pages et paramètres d'un module n'apparaissent que lorsqu'il est actif.
    </p>

    <div class="d-flex flex-column gap-2" id="module-list">
        {% for mod in modules %}
            <div class="border rounded-3 p-3">
                <div class="d-flex align-items-start justify-content-between gap-3">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="fw-semibold">{{ mod.manifest.name }}</span>
                            {% if mod.enabled %}
                                <span class="badge bg-success-subtle text-success-emphasis">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Inactif</span>
                            {% endif %}
                            <span class="text-body-tertiary" style="font-size:0.75rem;">
                                v{{ mod.manifest.version }}
                            </span>
                            {% if mod.validationError %}
                                <span class="badge bg-danger-subtle text-danger-emphasis"
                                      title="{{ mod.validationError }}">Erreur</span>
                            {% endif %}
                            {% if not mod.presentOnDisk %}
                                <span class="badge bg-warning-subtle text-warning-emphasis">Manquant</span>
                            {% endif %}
                        </div>
                        {% if mod.manifest.description %}
                            <p class="text-body-secondary small mb-0 mt-1">{{ mod.manifest.description }}</p>
                        {% endif %}
                    </div>
                    {% if mod.presentOnDisk and not mod.validationError %}
                        <div class="form-check form-switch">
                            <input class="form-check-input module-toggle"
                                   type="checkbox" data-module="{{ mod.manifest.id }}"
                                   {{ mod.enabled ? 'checked' : '' }}>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}

        {% if modules is empty %}
            <p class="text-body-secondary fst-italic">
                Aucun module disponible. Placez des modules dans le répertoire
                <code>modules/</code> pour les voir apparaître ici.
            </p>
        {% endif %}
    </div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}">
document.querySelectorAll('.module-toggle').forEach(toggle => {
    toggle.addEventListener('change', async () => {
        const moduleId = toggle.dataset.module;
        const enabled = toggle.checked;
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
        const res = await fetch('/config/general/module-toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ module_id: moduleId, enabled, _csrf_token: csrf })
        });
        const data = await res.json();
        if (!data.success) {
            alert(data.error);
            toggle.checked = !enabled;
        } else {
            window.location.reload();
        }
    });
});

const badgeCsrf = () => document.querySelector('meta[name="csrf-token"]')?.content;

document.querySelectorAll('.badge-row').forEach(row => {
    const badgeId = parseInt(row.dataset.id);
    const isDefault = row.dataset.default === '1';
    const nameInput = row.querySelector('.badge-name-input');
    const activeInput = row.querySelector('.badge-active-input');
    const deleteBtn = row.querySelector('.badge-delete-btn');

    if (!isDefault) {
        nameInput.addEventListener('blur', async () => {
            const res = await fetch('/config/general/badge-update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ badge_id: badgeId, name: nameInput.value, _csrf_token: badgeCsrf() })
            });
            const data = await res.json();
            if (!data.success) {
                alert(data.error);
            } else {
                window.location.reload();
            }
        });
    }

    activeInput.addEventListener('change', async () => {
        activeInput.disabled = true;
        const res = await fetch('/config/general/badge-toggle-active', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ badge_id: badgeId, active: activeInput.checked, _csrf_token: badgeCsrf() })
        });
        const data = await res.json();
        activeInput.disabled = false;
        if (!data.success) {
            alert(data.error);
            activeInput.checked = !activeInput.checked;
        }
    });

    deleteBtn?.addEventListener('click', async () => {
        if (!confirm('Supprimer définitivement ce badge ?')) return;
        const res = await fetch('/config/general/badge-delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ badge_id: badgeId, _csrf_token: badgeCsrf() })
        });
        const data = await res.json();
        if (!data.success) {
            alert(data.error);
        } else {
            row.remove();
        }
    });
});

document.getElementById('badge-add-btn').addEventListener('click', async () => {
    const nameInput = document.getElementById('new-badge-name');

    const res = await fetch('/config/general/badge-add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: nameInput.value, _csrf_token: badgeCsrf() })
    });
    const data = await res.json();
    if (!data.success) {
        alert(data.error);
    } else {
        window.location.reload();
    }
});
</script>
{% endblock %}
