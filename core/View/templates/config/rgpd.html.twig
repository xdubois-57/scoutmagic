{% extends "base.html.twig" %}

{% block title %}Configuration RGPD — {{ site_name }}{% endblock %}

{% block content %}
<h1 class="h3 mb-4">Configuration de la page RGPD</h1>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h6 mb-3">Mode de génération du contenu</h2>
        <p class="text-body-secondary">
            Choisissez comment le contenu de la page RGPD publique est généré.
        </p>

        <div class="mb-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="mode" id="mode-default" value="default" {{ mode == 'default' ? 'checked' : '' }}>
                <label class="form-check-label" for="mode-default">
                    <strong>Par défaut</strong> — Contenu RGPD standard et complet
                </label>
                <div class="form-text">
                    Aucune personnalisation possible. Couvre le noyau du site ainsi que tous les modules disponibles, qu'ils soient actifs ou non sur ce site.
                </div>
            </div>

            <div class="form-check mt-3">
                <input class="form-check-input" type="radio" name="mode" id="mode-custom" value="custom" {{ mode == 'custom' ? 'checked' : '' }}>
                <label class="form-check-label" for="mode-custom">
                    <strong>Personnalisé</strong> — Modifiez le texte librement
                </label>
                <div class="form-text">
                    Vous êtes responsable de la conformité RGPD du contenu saisi.
                </div>
            </div>

            {% if llm_available %}
            <div class="form-check mt-3">
                <input class="form-check-input" type="radio" name="mode" id="mode-ai" value="ai" {{ mode == 'ai' ? 'checked' : '' }}>
                <label class="form-check-label" for="mode-ai">
                    <strong>Généré par IA</strong> — Le contenu est généré automatiquement
                </label>
                <div class="form-text">
                    Basé sur le contenu par défaut, les modules actifs et votre prompt personnalisé.
                </div>
            </div>
            {% else %}
            <div class="form-check mt-3 disabled">
                <input class="form-check-input" type="radio" name="mode" id="mode-ai" value="ai" disabled>
                <label class="form-check-label text-muted" for="mode-ai">
                    <strong>Généré par IA</strong> — Module IA non activé
                </label>
                <div class="form-text">
                    Activez le module « Connecteur IA » pour utiliser cette option.
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="card mb-4" id="ai-prompt-card" style="display: none;">
    <div class="card-body">
        <h2 class="h6 mb-3">Prompt de personnalisation (IA)</h2>
        <p class="text-body-secondary">
            Instructions pour personnaliser le contenu généré (ton, ajouts, précisions).
            Le contenu par défaut et les modules actifs sont toujours inclus automatiquement.
        </p>
        <textarea class="form-control font-monospace" id="ai-prompt" rows="6" placeholder="Nous utilisons les services Google (par exemple Drive, Gmail et Google Photos) pour stocker des documents pouvant contenir des données à caractère personnel, ainsi que des photos. Cela signifie que ces données peuvent être hébergées sur des serveurs situés aux États-Unis.
Les fiches médicales sont collectées au format papier et sont utilisées uniquement dans le cadre du camp.
L'unité dispose également d'un groupe Facebook destiné aux parents et aux anciens membres, sur lequel elle peut occasionnellement publier des photos.">{%- if prompt -%}{{ prompt }}{%- endif -%}</textarea>
        <div class="mt-3">
            <button type="button" class="btn btn-primary" id="generate-btn">
                <i class="bi bi-stars"></i> Générer le contenu
            </button>
            <span class="text-body-secondary ms-3" id="generate-status"></span>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0">Contenu actuel</h2>
            <div>
                <button type="button" class="btn btn-sm btn-outline-primary rich-text-field-edit-btn" id="edit-content-btn"
                        data-key="rgpd.text" data-save-url="/config/rgpd/save" title="Modifier">
                    <i class="bi bi-pencil"></i> Modifier
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="reset-btn">
                    <i class="bi bi-arrow-counterclockwise"></i> Réinitialiser
                </button>
            </div>
        </div>
        <div class="rich-text-field-preview border rounded p-3" data-key="rgpd.text" style="min-height: 200px;">
            {{ current_content|raw }}
        </div>
    </div>
</div>

{% include 'partials/rich_text_editor.html.twig' %}
{% endblock %}

{% block scripts %}
<script src="/assets/js/rich-text-field.js" defer></script>
<script nonce="{{ csp_nonce }}">
document.addEventListener('DOMContentLoaded', function() {
    var modeRadios = document.querySelectorAll('input[name="mode"]');
    var aiPromptCard = document.getElementById('ai-prompt-card');
    var generateBtn = document.getElementById('generate-btn');
    var resetBtn = document.getElementById('reset-btn');
    var editBtn = document.getElementById('edit-content-btn');
    var preview = document.querySelector('.rich-text-field-preview[data-key="rgpd.text"]');
    var aiPromptTextarea = document.getElementById('ai-prompt');
    var generateStatus = document.getElementById('generate-status');

    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var csrf = csrfMeta ? csrfMeta.content : '';
    var generationTimer = null;

    function getMode() {
        var checked = document.querySelector('input[name="mode"]:checked');
        return checked ? checked.value : 'default';
    }

    function updateUI() {
        var mode = getMode();
        aiPromptCard.style.display = mode === 'ai' ? 'block' : 'none';
        editBtn.style.display = (mode === 'custom' || mode === 'ai') ? 'inline-block' : 'none';
    }

    // Debug helper: reads the response as text first so that, if the body
    // isn't valid JSON (e.g. an uncaught PHP error produced an HTML error
    // page instead of a JSON response), we log the raw status/content-type/
    // body to the console instead of letting response.json() throw an
    // opaque "The string did not match the expected pattern." (Safari) or
    // "Unexpected token" (Chrome) error.
    function parseJsonResponse(response) {
        return response.text().then(function(text) {
            console.log('[RGPD debug] status=' + response.status + ' content-type=' + response.headers.get('content-type'));
            try {
                return JSON.parse(text);
            } catch (parseErr) {
                console.error('[RGPD debug] Réponse non-JSON reçue du serveur :', text);
                throw new Error('Réponse serveur invalide (voir la console pour le détail).');
            }
        });
    }

    function startGenerationTimer(baseMessage) {
        var seconds = 0;
        if (generationTimer !== null) {
            clearInterval(generationTimer);
        }
        generateStatus.textContent = baseMessage + ' (' + seconds + 's)';
        generationTimer = setInterval(function() {
            seconds += 1;
            generateStatus.textContent = baseMessage + ' (' + seconds + 's)';
        }, 1000);
    }

    function stopGenerationTimer() {
        if (generationTimer !== null) {
            clearInterval(generationTimer);
            generationTimer = null;
        }
    }

    function saveMode(mode, content, prompt, callback) {
        fetch('/config/rgpd/save', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ _csrf_token: csrf, mode: mode, content: content, prompt: prompt })
        })
        .then(parseJsonResponse)
        .then(function(result) {
            if (callback) callback(result.success, result);
        })
        .catch(function(err) {
            console.error('[RGPD debug] saveMode error:', err);
            if (callback) callback(false);
        });
    }

    // Auto-save on mode change
    modeRadios.forEach(function(radio) {
        radio.addEventListener('change', function() {
            var mode = getMode();
            updateUI();
            
            if (mode === 'default') {
                // Reset to default content, then persist mode + content
                fetch('/config/rgpd/reset', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ _csrf_token: csrf })
                })
                .then(parseJsonResponse)
                .then(function(result) {
                    if (result.success) {
                        preview.innerHTML = result.content;
                        saveMode('default', result.content, '', function(success) {
                            // Silent save
                        });
                    }
                })
                .catch(function(err) {
                    console.error('[RGPD debug] reset error:', err);
                });
            } else if (mode === 'ai') {
                // Reset to default first, then auto-generate if prompt exists
                fetch('/config/rgpd/reset', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ _csrf_token: csrf })
                })
                .then(parseJsonResponse)
                .then(function(result) {
                    if (result.success) {
                        preview.innerHTML = result.content;
                        
                        // Auto-generate if prompt exists
                        var prompt = aiPromptTextarea.value.trim();
                        if (prompt) {
                            startGenerationTimer('Génération automatique en cours…');
                            generateBtn.disabled = true;
                            
                            fetch('/config/rgpd/generate', {
                                method: 'POST',
                                headers: {'Content-Type': 'application/json'},
                                body: JSON.stringify({ _csrf_token: csrf, prompt: prompt })
                            })
                            .then(parseJsonResponse)
                            .then(function(result) {
                                stopGenerationTimer();
                                if (result.success) {
                                    preview.innerHTML = result.content;
                                    generateStatus.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> Contenu généré automatiquement</span>';
                                    setTimeout(function() { generateStatus.textContent = ''; }, 5000);
                                } else {
                                    generateStatus.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> ' + result.error + '</span>';
                                }
                            })
                            .catch(function(err) {
                                stopGenerationTimer();
                                console.error('[RGPD debug] generate (auto) error:', err);
                                generateStatus.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> Erreur : ' + err.message + '</span>';
                            })
                            .finally(function() { generateBtn.disabled = false; });
                        }
                    }
                })
                .catch(function(err) {
                    console.error('[RGPD debug] reset (before AI) error:', err);
                });
            } else if (mode === 'custom') {
                // Keep current version, save mode
                saveMode(mode, preview.innerHTML, '', function(success) {
                    // Silent save
                });
            }
        });
    });
    
    updateUI();

    // Override the rich-text-field edit button: open the shared modal but
    // do NOT save via the default URL — we handle save ourselves below.
    editBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        
        var modalEl = document.getElementById('richTextEditorModal');
        var editorContent = document.getElementById('richTextEditorContent');
        if (!modalEl || !editorContent) return;
        editorContent.innerHTML = preview.innerHTML;
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        
        // Hide the default Save button and show our custom one
        var defaultSaveBtn = document.getElementById('richTextEditorSave');
        var customSaveBtn = document.getElementById('rgpd-modal-save');
        if (defaultSaveBtn) defaultSaveBtn.style.display = 'none';
        if (customSaveBtn) customSaveBtn.style.display = 'inline-block';
        
        modal.show();
    });
    
    // Custom save button for RGPD modal
    var customSaveBtn = document.createElement('button');
    customSaveBtn.id = 'rgpd-modal-save';
    customSaveBtn.className = 'btn btn-primary';
    customSaveBtn.textContent = 'Enregistrer';
    customSaveBtn.style.display = 'none';
    customSaveBtn.addEventListener('click', function() {
        var modalEl = document.getElementById('richTextEditorModal');
        var editorContent = document.getElementById('richTextEditorContent');
        var newContent = editorContent.innerHTML;
        preview.innerHTML = newContent;
        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.hide();
        
        // Auto-save the new content
        var mode = getMode();
        var prompt = aiPromptTextarea.value;
        saveMode(mode, newContent, prompt, function(success) {
            // Silent save - content already updated in preview
        });
        
        // Restore default Save button
        var defaultSaveBtn = document.getElementById('richTextEditorSave');
        if (defaultSaveBtn) defaultSaveBtn.style.display = 'inline-block';
        customSaveBtn.style.display = 'none';
    });
    
    // Add custom save button to modal footer
    var modalFooter = document.querySelector('#richTextEditorModal .modal-footer');
    if (modalFooter) {
        var defaultSaveBtn = document.getElementById('richTextEditorSave');
        if (defaultSaveBtn && defaultSaveBtn.parentNode) {
            defaultSaveBtn.parentNode.insertBefore(customSaveBtn, defaultSaveBtn);
        }
    }

    // Manual generate button (when in AI mode)
    generateBtn.addEventListener('click', function() {
        var prompt = aiPromptTextarea.value;
        startGenerationTimer('Génération en cours…');
        generateBtn.disabled = true;

        fetch('/config/rgpd/generate', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ _csrf_token: csrf, prompt: prompt })
        })
        .then(parseJsonResponse)
        .then(function(result) {
            stopGenerationTimer();
            if (result.success) {
                preview.innerHTML = result.content;
                generateStatus.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> Contenu généré et enregistré</span>';
                setTimeout(function() { generateStatus.textContent = ''; }, 5000);
            } else {
                generateStatus.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> ' + result.error + '</span>';
            }
        })
        .catch(function(err) {
            stopGenerationTimer();
            console.error('[RGPD debug] generate (manual) error:', err);
            generateStatus.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> Erreur : ' + err.message + '</span>';
        })
        .finally(function() { generateBtn.disabled = false; });
    });

    // Reset button - resets to default content and persists it for the current mode
    resetBtn.addEventListener('click', function() {
        if (!confirm('Réinitialiser au contenu par défaut ?')) return;

        fetch('/config/rgpd/reset', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ _csrf_token: csrf })
        })
        .then(parseJsonResponse)
        .then(function(result) {
            if (result.success) {
                preview.innerHTML = result.content;
                saveMode(getMode(), result.content, aiPromptTextarea.value, function(success) {
                    // Silent save
                });
            }
        })
        .catch(function(err) {
            console.error('[RGPD debug] reset (button) error:', err);
        });
    });
});
</script>
{% endblock %}
