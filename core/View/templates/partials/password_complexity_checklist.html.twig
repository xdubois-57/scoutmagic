{#
    Reusable live complexity checklist — shared by the password-reset page
    and the account page's change-password box (Core\Security\
    PasswordPolicy is the server-side twin of this same rule set).
    Include once per password input, then call
    initPasswordComplexityChecklist('<input id>', '<list id>') from
    assets/js/password-complexity.js.
#}
<ul class="list-unstyled small mb-0" id="{{ list_id }}">
    <li class="pwd-rule" data-rule="length"><i class="bi bi-circle text-body-secondary me-1"></i>Au moins 12 caractères</li>
    <li class="pwd-rule" data-rule="uppercase"><i class="bi bi-circle text-body-secondary me-1"></i>Au moins une majuscule</li>
    <li class="pwd-rule" data-rule="lowercase"><i class="bi bi-circle text-body-secondary me-1"></i>Au moins une minuscule</li>
    <li class="pwd-rule" data-rule="digit"><i class="bi bi-circle text-body-secondary me-1"></i>Au moins un chiffre</li>
    <li class="pwd-rule" data-rule="symbol"><i class="bi bi-circle text-body-secondary me-1"></i>Au moins un caractère spécial (!@#$%...)</li>
</ul>
