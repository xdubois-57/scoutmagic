{# Mobile header bar — visible below lg #}
<header class="d-lg-none d-flex align-items-center px-3 border-bottom bg-white" style="height:56px;">
    <button class="btn btn-link text-dark p-2 me-auto d-inline-flex align-items-center justify-content-center" type="button" data-bs-toggle="offcanvas" data-bs-target="#navOffcanvas" aria-label="Menu" style="min-width:44px;min-height:44px;">
        <i class="bi bi-list fs-3"></i>
    </button>
    <span class="fw-semibold">{{ site_name }}</span>
</header>

{# Mobile offcanvas — slides from left #}
<div class="offcanvas offcanvas-start d-lg-none" tabindex="-1" id="navOffcanvas" aria-label="Navigation">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title">{{ site_name }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column p-0">
        {% if is_authenticated %}
        <a href="/account" class="d-block p-3 border-bottom bg-light text-decoration-none text-body">
            <div class="d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold" style="width:40px;height:40px;font-size:.9rem;">
                    {{ current_user_display_name[:2]|upper }}
                </span>
                <div>
                    <div class="fw-semibold small text-truncate" style="max-width:180px;">{{ current_user_display_name }}</div>
                    <div class="text-muted" style="font-size:.75rem;">
                        {{ current_user_role_label }}
                        {% if current_user_member_count > 0 %}
                            · {{ current_user_member_count }} membre{{ current_user_member_count > 1 ? 's' : '' }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </a>
        {% endif %}

        <div class="accordion accordion-flush flex-grow-1 overflow-auto" id="mobileMenuAccordion">
            {% for menu in menus %}
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button {% if not menu.id == active_menu_id %}collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#mob-{{ menu.id }}" aria-expanded="{{ menu.id == active_menu_id ? 'true' : 'false' }}">
                        <i class="bi {{ menu.icon }} me-2"></i> {{ menu.label }}
                    </button>
                </h2>
                <div id="mob-{{ menu.id }}" class="accordion-collapse collapse {% if menu.id == active_menu_id %}show{% endif %}" data-bs-parent="#mobileMenuAccordion">
                    <div class="accordion-body p-0">
                        <ul class="list-group list-group-flush">
                            {% for page in menu.pages %}
                                {% if page.isSeparator %}
                                    <li class="list-group-item p-0"><hr class="my-1"></li>
                                {% elseif page.isDynamic %}
                                    <li class="list-group-item list-group-item-action border-0 ps-4{% if current_path == page.url %} active{% endif %}" style="min-height:44px;">
                                        <a href="{{ page.url }}" class="d-flex align-items-center gap-2 text-decoration-none{% if current_path == page.url %} fw-semibold text-primary{% else %} text-dark{% endif %}"{{ current_path == page.url ? ' aria-current="page"' : '' }}>
                                            <div class="rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center"
                                                 style="width:32px;height:32px;min-width:32px;">
                                                <span class="small fw-semibold text-primary">{{ page.label[:2] }}</span>
                                            </div>
                                            <div class="lh-sm">
                                                <span class="d-block small">{{ page.label }}</span>
                                                {% if page.subtitle %}
                                                    <span class="d-block text-body-secondary" style="font-size:0.75rem;">{{ page.subtitle }}</span>
                                                {% endif %}
                                            </div>
                                        </a>
                                    </li>
                                {% else %}
                                    <li class="list-group-item list-group-item-action border-0 ps-4 d-flex align-items-center{% if current_path == page.url %} active{% endif %}" style="min-height:44px;">
                                        <a href="{{ page.url }}" class="text-decoration-none d-block{% if current_path == page.url %} fw-semibold text-primary{% else %} text-dark{% endif %}"{{ current_path == page.url ? ' aria-current="page"' : '' }}>{{ page.label }}</a>
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="p-3 border-top mt-auto">
            {% if is_authenticated %}
            <form method="post" action="/logout">
                {{ csrf_field()|raw }}
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">Se déconnecter</button>
            </form>
            {% else %}
            <a href="/login" class="btn btn-primary btn-sm w-100">Se connecter</a>
            {% endif %}
        </div>
    </div>
</div>

{# Desktop navigation — visible at lg and above #}
<nav class="d-none d-lg-block border-bottom bg-white" id="desktopNav">
    <div class="container-fluid d-flex align-items-center px-3" style="height:56px;">
        <a href="/" class="text-decoration-none text-dark fw-semibold me-4">{{ site_name }}</a>

        <div class="d-flex align-items-center gap-1 flex-grow-1" id="desktopMenus">
            {% for menu in menus %}
            <button type="button"
                    class="btn btn-sm {% if menu.id == active_menu_id %}btn-primary{% else %}btn-outline-secondary{% endif %} desktop-menu-btn"
                    data-menu-id="{{ menu.id }}">
                <i class="bi {{ menu.icon }} me-1"></i>{{ menu.label }}
            </button>
            {% endfor %}
        </div>

        <div class="ms-auto">
            {% if is_authenticated %}
            <div class="d-flex align-items-center gap-2">
                <a href="/account" class="d-flex align-items-center gap-2 text-decoration-none text-body">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold" style="width:32px;height:32px;font-size:.8rem;">
                        {{ current_user_display_name[:2]|upper }}
                    </span>
                    <span class="small text-truncate" style="max-width:160px;">{{ current_user_display_name }}</span>
                    {% if current_user_member_count > 0 %}
                        <span class="text-muted" style="font-size:.75rem;">· {{ current_user_member_count }} membre{{ current_user_member_count > 1 ? 's' : '' }}</span>
                    {% endif %}
                </a>
                <form method="post" action="/logout" class="d-inline ms-2">
                    {{ csrf_field()|raw }}
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Se déconnecter</button>
                </form>
            </div>
            {% else %}
            <a href="/login" class="btn btn-primary btn-sm">Se connecter</a>
            {% endif %}
        </div>
    </div>

    {# Sub-menu bars #}
    {% for menu in menus %}
    <div class="desktop-submenu border-top bg-light {% if menu.id != active_menu_id %}d-none{% endif %}" data-submenu-id="{{ menu.id }}">
        <div class="container-fluid px-3 py-2 d-flex flex-wrap gap-2">
            {% for page in menu.pages %}
                {% if page.isSeparator %}
                    <span class="border-start mx-1" style="height:24px;"></span>
                {% elseif page.isDynamic %}
                    <a href="{{ page.url }}"
                       class="btn btn-sm {% if current_path == page.url %}btn-primary{% else %}btn-outline-secondary{% endif %} d-flex align-items-center gap-1">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary fw-bold"
                              style="width:20px;height:20px;font-size:.7rem;">
                            {{ page.label[:2] }}
                        </span>
                        <span>{{ page.label }}</span>
                    </a>
                {% else %}
                    <a href="{{ page.url }}"
                       class="btn btn-sm {% if current_path == page.url %}btn-primary{% else %}btn-outline-secondary{% endif %}">
                        {{ page.label }}
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    </div>
    {% endfor %}
</nav>
