{% extends 'base.html.twig' %}
{% block title %}Staffs — {{ site_name }}{% endblock %}
{% block stylesheets %}
<link rel="stylesheet" href="/assets/css/components.css">
{% endblock %}
{% block content %}
<div class="mx-auto" style="max-width:720px;">
    <h1 class="mb-3">Staffs</h1>

    {% if sections|length > 0 %}
        {% include 'partials/section_picker.html.twig' with {
            sections: sections,
            selected_id: current_section.id|default(0),
            base_url: '/chefs/staffs?section='
        } %}
    {% endif %}

    {% if current_section %}
        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
            <span class="fw-semibold fs-5">{{ current_section.name ?? current_section.desk_code }}</span>
            <span class="badge bg-secondary-subtle text-secondary-emphasis">
                {{ current_section.branch_name }}
            </span>
            <span class="text-body-secondary small">{{ staff|length }} animateur{{ staff|length > 1 ? 's' : '' }}</span>
            {% if can_edit_section %}
                <button type="button" class="btn btn-sm btn-link text-body-secondary ms-auto p-0"
                        id="edit-section-btn" title="Modifier les informations de la section">
                    <i class="bi bi-pencil"></i>
                </button>
            {% endif %}
        </div>
        <p class="text-body-secondary small mb-3">
            {{ current_section.email ?? 'Aucun email configuré' }}
            · code {{ current_section.desk_code }}
        </p>

        {% if not current_section.name %}
            <div class="alert alert-warning small py-2 mb-3">
                <i class="bi bi-exclamation-triangle"></i>
                Cette section n'a pas encore de nom configuré.
                {% if can_edit_section %}
                    Cliquez sur <i class="bi bi-pencil"></i> pour le définir.
                {% endif %}
            </div>
        {% endif %}

        {% if can_edit_section %}
            <div id="section-edit-form" class="card mb-3" style="display:none;">
                <div class="card-body">
                    <h2 class="h6 mb-2">Informations de la section</h2>
                    <p class="text-body-secondary small mb-3">
                        Code Desk : {{ current_section.desk_code }}
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Nom</label>
                        <input type="text" id="section-name" class="form-control"
                               value="{{ current_section.name }}"
                               placeholder="{{ current_section.desk_code }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" id="section-email" class="form-control"
                               value="{{ current_section.email }}"
                               placeholder="section@unite-exemple.be">
                        <div class="form-text">
                            Adresse email organisationnelle de la section, utilisée pour les communications avec les parents.
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-sm btn-secondary" id="section-edit-cancel">
                            Annuler
                        </button>
                        <button type="button" class="btn btn-sm btn-primary" id="section-edit-save">
                            Enregistrer
                        </button>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="d-flex flex-column gap-2">
            {% for member in staff %}
                <div class="card">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center"
                                 style="width:40px;height:40px;min-width:40px;">
                                <span class="small fw-semibold text-primary">
                                    {{ member.getDisplayName()[:2] }}
                                </span>
                            </div>
                            <div>
                                <span class="fw-semibold">{{ member|display_name }}</span>
                                {% if member.getMainFunction() %}
                                <div class="text-body-secondary small">
                                    {{ member.getMainFunction().functionLabel }}
                                </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-3 small">
                            {% if member.formationLevel %}
                                <span>
                                    <i class="bi bi-mortarboard text-body-secondary"></i>
                                    {{ member.formationLevel }}
                                </span>
                            {% endif %}
                            {% if member.mobile %}
                                <a href="tel:{{ member.mobile }}" class="text-decoration-none">
                                    <i class="bi bi-phone text-body-secondary"></i>
                                    {{ member.mobile }}
                                </a>
                            {% elseif member.phone %}
                                <a href="tel:{{ member.phone }}" class="text-decoration-none">
                                    <i class="bi bi-telephone text-body-secondary"></i>
                                    {{ member.phone }}
                                </a>
                            {% endif %}
                            {% if member.email %}
                                <a href="mailto:{{ member.email }}" class="text-decoration-none text-truncate"
                                   style="max-width:200px;">
                                    <i class="bi bi-envelope text-body-secondary"></i>
                                    {{ member.email }}
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="text-body-secondary fst-italic">Aucun animateur dans cette section.</p>
            {% endfor %}
        </div>
    {% else %}
        <p class="text-body-secondary">
            Aucune section disponible. Les sections apparaîtront après le premier import Desk.
        </p>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
{% if can_edit_section is defined and can_edit_section and current_section is defined and current_section %}
<script nonce="{{ csp_nonce }}">
const editBtn = document.getElementById('edit-section-btn');
const editForm = document.getElementById('section-edit-form');
const cancelBtn = document.getElementById('section-edit-cancel');
const saveBtn = document.getElementById('section-edit-save');

editBtn?.addEventListener('click', () => { editForm.style.display = 'block'; editBtn.style.display = 'none'; });
cancelBtn?.addEventListener('click', () => { editForm.style.display = 'none'; editBtn.style.display = ''; });

saveBtn?.addEventListener('click', async () => {
    const name = document.getElementById('section-name').value;
    const email = document.getElementById('section-email').value;
    const csrf = document.querySelector('meta[name="csrf-token"]')?.content;

    const res = await fetch('/chefs/staffs/update-section', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            section_id: {{ current_section.id }},
            name, email, _csrf_token: csrf
        })
    });
    const data = await res.json();
    if (data.success) { window.location.reload(); }
    else { alert(data.error); }
});
</script>
{% endif %}
{% endblock %}
