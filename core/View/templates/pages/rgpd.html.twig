{% extends "base.html.twig" %}

{% block title %}Protection des données — {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="mb-4">Protection des données</h1>

    {{ rgpd_content|raw }}

    <h2 class="mt-5">Cookies utilisés</h2>
    <p>
        Vous pouvez modifier vos préférences à tout moment sur la
        <a href="/cookies">page de préférences cookies</a>.
    </p>

    {% for category_id, category in cookie_categories %}
        <h3>{{ category.label }}{% if category_id == 'necessary' %} (toujours actifs){% endif %}</h3>
        <p>{{ category.description }}</p>

        {% if category.cookies|length > 0 %}
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Cookie</th>
                        <th>Finalité</th>
                        <th>Durée</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cookie in category.cookies %}
                        <tr>
                            <td><code>{{ cookie.name }}</code></td>
                            <td>{{ cookie.purpose }}</td>
                            <td>{{ cookie.duration }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="text-body-secondary fst-italic">
                Aucun cookie dans cette catégorie actuellement.
            </p>
        {% endif %}
    {% endfor %}
{% endblock %}
