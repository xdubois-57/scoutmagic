<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>{% block title %}{{ site_name }}{% endblock %}</title>
    {% block head_meta %}{% endblock %}
    <link rel="stylesheet" href="/assets/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/vendor/bootstrap-icons/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/assets/css/app.css">
    {% if config_mode is defined and config_mode %}
    <link rel="stylesheet" href="/assets/css/editable.css">
    {% endif %}
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block nav %}
    {% if menus is defined and menus is not null %}
        {% include 'partials/nav.html.twig' with {
            menus: menus,
            current_path: current_path|default('/'),
            is_authenticated: is_authenticated|default(false),
            user_display_name: current_user_display_name|default(''),
            user_role_label: current_user_role_label|default(''),
            site_name: site_name|default('Unité scoute'),
            active_menu_id: active_menu_id|default('')
        } %}
    {% endif %}
    {% endblock %}

    {% if config_mode is defined and config_mode %}
    <div class="alert alert-warning d-flex align-items-center gap-2 rounded-0 mb-0 border-start-0 border-end-0" role="alert">
        <i class="bi bi-exclamation-triangle"></i>
        <span>Mode configuration actif — les textes et images du site sont éditables.</span>
        <form method="post" action="/config-mode/deactivate" class="ms-auto">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn btn-sm btn-outline-warning">Désactiver</button>
        </form>
    </div>
    {% endif %}

    {% if year_override_type is defined and year_override_type == 'session' %}
    <div class="alert alert-warning d-flex align-items-center gap-2 rounded-0 mb-0 border-start-0 border-end-0" role="alert">
        <i class="bi bi-clock-history"></i>
        <span>Vous visualisez le site en {{ effective_scout_year }} (session uniquement).</span>
        <form method="post" action="/admin/scout-year/clear-preview" class="ms-auto">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn-close" aria-label="Revenir à l'année courante"></button>
        </form>
    </div>
    {% elseif year_override_type is defined and year_override_type == 'staff' %}
    <div class="alert alert-info d-flex align-items-center gap-2 rounded-0 mb-0 border-start-0 border-end-0" role="alert">
        <i class="bi bi-info-circle"></i>
        <span>Le staff voit actuellement l'année {{ effective_scout_year }}.</span>
    </div>
    {% endif %}

    <main class="container py-3">
        {% set flash = get_flash() %}
        {% if flash %}
        <div class="alert alert-{{ flash.type == 'error' ? 'danger' : flash.type }} alert-dismissible fade show" role="alert">
            {{ flash.message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
        {% endif %}
        {% block content %}{% endblock %}
    </main>

    {% block footer %}
    <footer class="border-top py-3 mt-4">
        <div class="container d-flex flex-wrap justify-content-between align-items-center small text-body-secondary">
            <span>{{ site_name }}</span>
            <div class="d-flex gap-3">
                <a href="/rgpd" class="text-body-secondary text-decoration-none">Protection des données</a>
                <a href="/cookies" class="text-body-secondary text-decoration-none">Préférences cookies</a>
                <a href="https://github.com/xdubois-57/scoutmagic" class="text-body-secondary text-decoration-none" target="_blank" rel="noopener">GitHub</a>
            </div>
        </div>
    </footer>
    {% endblock %}

    <script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/nav.js"></script>
    {% if config_mode is defined and config_mode %}
    {% include 'partials/rich_text_editor.html.twig' %}
    <script src="/assets/js/editable.js" defer></script>
    {% endif %}
    <script src="/assets/js/cookie-consent.js" defer></script>
    {% block scripts %}{% endblock %}

    {% if cookie_consent_given is defined and not cookie_consent_given %}
        {% include 'partials/cookie_banner.html.twig' %}
    {% endif %}
</body>
</html>
