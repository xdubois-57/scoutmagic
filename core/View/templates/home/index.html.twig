{% extends "base.html.twig" %}

{% block title %}Bienvenue — {{ site_name }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <h1 class="mb-4">Bienvenue</h1>
        <p class="lead">Bienvenue sur le site de <strong>{{ site_name }}</strong>.</p>

        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title">Notre unité</h5>
                <p class="card-text">Ce site est en cours de construction. Revenez bientôt pour découvrir nos activités et nos sections.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
