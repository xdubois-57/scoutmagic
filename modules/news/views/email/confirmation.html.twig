{% extends 'email/base.html.twig' %}
{% block content %}
    <h2 style="margin:0 0 16px;font-size:20px;">Confirmation — {{ article_title }}</h2>
    <p>Votre réponse a bien été enregistrée. Voici un récapitulatif :</p>

    <table style="width:100%;border-collapse:collapse;margin:16px 0;">
        {% for line in answers %}
            <tr>
                <td style="padding:6px 8px;border-bottom:1px solid #eee;font-weight:bold;width:40%;">{{ line.label }}</td>
                <td style="padding:6px 8px;border-bottom:1px solid #eee;">{{ line.value }}</td>
            </tr>
        {% endfor %}
    </table>

    {% if payment %}
        <div style="border:1px solid #ddd;border-radius:8px;padding:16px;margin:20px 0;background-color:#f8f9fa;">
            <p style="margin:0 0 8px;font-weight:bold;font-size:16px;">Montant à payer : {{ payment.total|number_format(2, ',', ' ') }} €</p>
            <p style="margin:0 0 4px;">Compte : {{ payment.beneficiary }}</p>
            <p style="margin:0 0 4px;">IBAN : {{ payment.iban }}</p>
            <p style="margin:0 0 12px;">Communication structurée : <strong>{{ payment.communication }}</strong></p>
            <p style="text-align:center;margin:12px 0;">
                <img src="{{ payment.qr_data_uri }}" alt="QR code SEPA" width="200" height="200">
            </p>
            <p style="font-size:12px;color:#666;">Scannez ce QR code avec votre application bancaire pour effectuer le paiement.</p>
        </div>
    {% endif %}

    {% if edit_url %}
        <p style="text-align:center;margin:24px 0;">
            <a href="{{ edit_url }}"
               style="display:inline-block;padding:10px 24px;background-color:#0d6efd;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;">
                Modifier mes réponses
            </a>
        </p>
    {% endif %}
{% endblock %}
