{% extends "base.html.twig" %}

{% block title %}Importer un relevé — Finances — {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="mb-4">Finances</h1>

    {% include '@finance/_nav.html.twig' with {'hide_account_picker': true} %}

    <p class="text-body-secondary small mb-3">
        Importez ici un relevé bancaire (export de votre banque) pour ajouter automatiquement les nouveaux
        mouvements au compte sélectionné — les mouvements déjà importés sont ignorés, et les règles de
        catégorisation configurées s'appliquent automatiquement à chaque ligne importée.
    </p>

    <h2 class="h5 mb-3">Importer un relevé bancaire</h2>

    <form method="post" action="/finance/import" enctype="multipart/form-data" class="border rounded-3 p-3" id="import-form">
        <div class="row g-2">
            <div class="col-12 col-md-4">
                <label class="form-label small" for="import-account">Compte</label>
                <select class="form-select form-select-sm" id="import-account" name="account_id">
                    {% for account in accounts %}
                        <option value="{{ account.id }}" data-first-import="{{ first_import_by_account_id[account.id] ? '1' : '0' }}" {{ selected_account and account.id == selected_account.id ? 'selected' : '' }}>{{ account.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label small" for="import-bank">Banque</label>
                <select class="form-select form-select-sm" id="import-bank" name="bank_code">
                    {% for code in bank_codes %}
                        <option value="{{ code }}">{{ code|upper }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label small" for="import-file">Fichier CSV</label>
                <input type="file" class="form-control form-control-sm" id="import-file" name="statement" accept=".csv" required>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small" for="import-balance">Solde après ce relevé</label>
                <input type="text" class="form-control form-control-sm" id="import-balance" name="balance" placeholder="1234,56">
                <div class="form-text small" id="import-balance-hint"></div>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-sm btn-primary">Importer</button>
            </div>
        </div>
    </form>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}">
const accountSelect = document.getElementById('import-account');
const balanceInput = document.getElementById('import-balance');
const balanceHint = document.getElementById('import-balance-hint');

function updateBalanceRequirement() {
    const option = accountSelect.options[accountSelect.selectedIndex];
    const isFirstImport = option && option.dataset.firstImport === '1';
    balanceInput.required = isFirstImport;
    balanceHint.textContent = isFirstImport
        ? "Premier import pour ce compte : le solde est obligatoire."
        : "Facultatif — laissez vide pour recalculer le solde automatiquement depuis les mouvements.";
}

accountSelect.addEventListener('change', updateBalanceRequirement);
updateBalanceRequirement();
</script>
{% endblock %}
