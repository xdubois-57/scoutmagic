{% extends "base.html.twig" %}

{% block title %}Exercices — Finances — {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="mb-4">Finances</h1>

    {% include '@finance/config/_nav.html.twig' %}

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Exercices</h2>
        <button type="button" class="btn btn-sm btn-primary" id="new-fiscal-year-btn">Nouvel exercice</button>
    </div>

    <div class="table-responsive mb-4">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Libellé</th>
                    <th>Début</th>
                    <th>Fin</th>
                    <th>Courant</th>
                </tr>
            </thead>
            <tbody>
                {% for fiscalYear in fiscal_years %}
                    <tr>
                        <td>{{ fiscalYear.label }}</td>
                        <td>{{ fiscalYear.startDate }}</td>
                        <td>{{ fiscalYear.endDate }}</td>
                        <td>
                            {% if fiscalYear.isCurrent %}
                                <span class="badge text-bg-success">Courant</span>
                            {% else %}
                                <button type="button" class="btn btn-sm btn-outline-secondary set-current-btn" data-id="{{ fiscalYear.id }}">Définir comme courant</button>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="4" class="text-body-secondary fst-italic">Aucun exercice.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="border rounded-3 p-3 mb-4 d-none" id="fiscal-year-form-container">
        <form id="fiscal-year-form" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label small" for="fiscal-year-label">Libellé</label>
                <input type="text" class="form-control form-control-sm" id="fiscal-year-label" placeholder="2026-2027" required>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small" for="fiscal-year-start">Début</label>
                <input type="date" class="form-control form-control-sm" id="fiscal-year-start" required>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small" for="fiscal-year-end">Fin</label>
                <input type="date" class="form-control form-control-sm" id="fiscal-year-end" required>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Créer</button>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary" id="cancel-fiscal-year-form">Annuler</button>
            </div>
            <div class="col-12 text-danger small d-none" id="fiscal-year-form-error"></div>
        </form>
    </div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}">
const csrf = () => document.querySelector('meta[name="csrf-token"]')?.content;
const formContainer = document.getElementById('fiscal-year-form-container');
const errorBox = document.getElementById('fiscal-year-form-error');

document.getElementById('new-fiscal-year-btn').addEventListener('click', () => {
    document.getElementById('fiscal-year-form').reset();
    formContainer.classList.remove('d-none');
    errorBox.classList.add('d-none');
});

document.getElementById('cancel-fiscal-year-form').addEventListener('click', () => {
    formContainer.classList.add('d-none');
});

document.getElementById('fiscal-year-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const res = await fetch('/config/finance/fiscal-years', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            action: 'create',
            label: document.getElementById('fiscal-year-label').value,
            start_date: document.getElementById('fiscal-year-start').value,
            end_date: document.getElementById('fiscal-year-end').value,
            _csrf_token: csrf()
        })
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        errorBox.textContent = data.error;
        errorBox.classList.remove('d-none');
    }
});

document.querySelectorAll('.set-current-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const res = await fetch('/config/finance/fiscal-years', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'set_current', id: parseInt(btn.dataset.id, 10), _csrf_token: csrf() })
        });
        const data = await res.json();
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.error);
        }
    });
});
</script>
{% endblock %}
