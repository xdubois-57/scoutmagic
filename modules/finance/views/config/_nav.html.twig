{#
  Config sub-page picker — same visual/interaction pattern as
  partials/section_picker.html.twig and @calendar/partials/calendar_picker.html.twig
  (a row of pill buttons, not Bootstrap nav-pills).
#}
{% set finance_nav_items = [
    {'url': '/config/finance', 'label': 'Vue d’ensemble'},
    {'url': '/config/finance/accounts', 'label': 'Comptes'},
    {'url': '/config/finance/categories', 'label': 'Catégories'},
] %}
<div class="d-flex flex-wrap gap-2 pb-2 mb-3 finance-config-picker">
    {% for item in finance_nav_items %}
        {% set is_active = current_path == item.url %}
        <a href="{{ item.url }}"
           class="btn btn-sm {{ is_active ? 'btn-primary' : 'btn-outline-secondary' }} text-nowrap text-decoration-none">
            {{ item.label }}
        </a>
    {% endfor %}
</div>
