{% set finance_nav_items = [
    {'url': '/config/finance', 'label': 'Vue d’ensemble'},
    {'url': '/config/finance/accounts', 'label': 'Comptes'},
    {'url': '/config/finance/categories', 'label': 'Catégories'},
    {'url': '/config/finance/rules', 'label': 'Règles de catégorisation'},
    {'url': '/config/finance/fiscal-years', 'label': 'Exercices'},
] %}
<ul class="nav nav-pills mb-4">
    {% for item in finance_nav_items %}
        <li class="nav-item">
            <a class="nav-link {{ current_path == item.url ? 'active' : '' }}" href="{{ item.url }}">{{ item.label }}</a>
        </li>
    {% endfor %}
</ul>
