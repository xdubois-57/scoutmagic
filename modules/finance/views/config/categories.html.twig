{% extends "base.html.twig" %}

{% block title %}Catégories — Finances — {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="mb-4">Finances</h1>

    {% include '@finance/config/_nav.html.twig' %}

    <p class="text-body-secondary small mb-4">
        Une <strong>catégorie</strong> classe les mouvements pour le bilan du tableau de bord (« Fête d'unité »,
        « Matériel », etc.) et a une <strong>description obligatoire</strong> — au-delà du nom, c'est ce qui permet
        à la règle de catégorisation par IA (ci-dessous) de vraiment distinguer les catégories entre elles. Une
        catégorie <strong>inactive</strong> reste utilisable pour les mouvements qui l'ont déjà, mais n'est plus
        proposée pour en catégoriser de nouveaux. Les <strong>règles de catégorisation</strong>, ci-dessous,
        attribuent automatiquement une catégorie à un mouvement importé selon son libellé, sa contrepartie ou son
        montant.
    </p>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">Catégories</h2>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="reset-default-categories-btn">Réinitialiser les catégories par défaut</button>
            <button type="button" class="btn btn-sm btn-primary" id="new-category-btn">Nouvelle catégorie</button>
        </div>
    </div>

    <div class="d-flex flex-column gap-2 mb-4">
        {% for category in categories %}
            <div class="border rounded-3 p-2 d-flex align-items-center gap-2">
                <div class="flex-grow-1">
                    <span class="category-name" data-id="{{ category.id }}">{{ category.name }}</span>
                    {% if category.isDefault %}<span class="badge text-bg-light border">Par défaut</span>{% endif %}
                    <div class="text-body-secondary small">{{ category.description }}</div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary edit-category-btn" data-id="{{ category.id }}" data-name="{{ category.name }}" data-description="{{ category.description }}" title="Modifier" aria-label="Modifier">
                    <i class="bi bi-pencil"></i>
                </button>
                <button type="button" class="btn btn-sm {{ category.isActive ? 'btn-outline-success' : 'btn-outline-secondary' }} toggle-category-btn"
                        data-id="{{ category.id }}" data-active="{{ category.isActive ? '1' : '0' }}"
                        title="{{ category.isActive ? 'Actif — cliquer pour désactiver' : 'Inactif — cliquer pour activer' }}"
                        aria-label="{{ category.isActive ? 'Actif — cliquer pour désactiver' : 'Inactif — cliquer pour activer' }}">
                    <i class="bi {{ category.isActive ? 'bi-toggle-on' : 'bi-toggle-off' }}"></i>
                </button>
                {% set movement_count = category_movement_counts[category.id] ?? 0 %}
                <button type="button" class="btn btn-sm btn-outline-danger delete-category-btn" data-id="{{ category.id }}"
                        {{ movement_count > 0 ? 'disabled' : '' }}
                        title="{{ movement_count > 0 ? 'Utilisée par ' ~ movement_count ~ ' mouvement(s) — ne peut pas être supprimée' : 'Supprimer' }}">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        {% else %}
            <p class="text-body-secondary fst-italic mb-0">Aucune catégorie.</p>
        {% endfor %}
    </div>

    <div class="modal fade" id="category-modal" tabindex="-1">
        <div class="modal-dialog modal-fullscreen-sm-down modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="category-form-title">Nouvelle catégorie</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="category-form">
                    <div class="modal-body">
                        <input type="hidden" id="category-id" value="">
                        <label class="form-label small" for="category-name">Nom</label>
                        <input type="text" class="form-control form-control-sm" id="category-name" required>
                        {% if recent_ai_suggestions %}
                            <div class="mt-2" id="category-suggestions">
                                <div class="text-body-secondary small mb-1">Suggestions récentes de l'IA :</div>
                                <div class="d-flex flex-wrap gap-1">
                                    {% for suggestion in recent_ai_suggestions %}
                                        <button type="button" class="btn btn-sm btn-outline-secondary category-suggestion-btn" data-name="{{ suggestion }}">{{ suggestion }}</button>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                        <div class="mt-2">
                            <label class="form-label small" for="category-description">Description</label>
                            <textarea class="form-control form-control-sm" id="category-description" rows="2" required
                                      placeholder="Ce à quoi sert cette catégorie — envoyé à l'IA pour choisir entre les catégories."></textarea>
                        </div>
                        <div class="text-danger small mt-2 d-none" id="category-form-error"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-sm btn-primary">Enregistrer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <hr class="my-4">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">Règles de catégorisation</h2>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="text-body-secondary small d-none" id="run-rules-status">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                Exécution en arrière-plan…
            </span>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="run-rules-btn">Exécuter les règles</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="reset-default-rules-btn">Réinitialiser par défaut</button>
            <button type="button" class="btn btn-sm btn-primary" id="new-rule-btn">Nouvelle règle</button>
        </div>
    </div>
    <p class="text-body-secondary small mb-2">
        Les règles sont évaluées dans l'ordre ci-dessous (glisser-déposer pour réordonner) ; la première qui
        correspond entièrement détermine la catégorie.
    </p>
    <div class="alert alert-info small mb-3">
        <p class="mb-1">
            Une règle peut combiner jusqu'à <strong>3 conditions à la fois</strong> — elles doivent
            <strong>toutes</strong> être remplies pour que la règle s'applique. Une règle sans aucune condition
            remplie ne s'applique jamais.
        </p>
        <ul class="mb-0 ps-3">
            <li>
                <strong>Mot-clé / expression régulière</strong> — comparé au libellé du mouvement, sans tenir
                compte de la casse ni des accents. Un mot simple comme <code>delhaize</code> fonctionne tel quel
                (il correspond à tout libellé qui contient ce mot, accentué ou non). Pour aller plus loin, c'est
                une expression régulière complète : <code>^VIR.*DUPONT$</code> (commence par « VIR » et finit par
                « DUPONT »), <code>REF[0-9]{6}</code> (« REF » suivi de 6 chiffres),
                <code>café|boulangerie</code> (l'un ou l'autre mot).
            </li>
            <li><strong>Compte contrepartie</strong> — tout ou partie de l'IBAN de la contrepartie (espaces et casse ignorés), ex. <code>BE71 0000 0000 0000</code>.</li>
            <li><strong>Montant</strong> — <code>&gt;100</code> (strictement plus de 100 €) ou <code>10-50</code> (entre 10 et 50 € inclus), toujours comparé à la valeur absolue du montant.</li>
        </ul>
    </div>

    <p class="text-body-secondary small mb-2">
        <i class="bi bi-gear-fill me-1"></i> Les règles marquées « Automatique » sont générées et maintenues par
        l'application (une par compte configuré, pour reconnaître les virements entre les comptes de l'unité) —
        elles ne sont pas modifiables ici. Les règles marquées « Par défaut » font partie du jeu de règles fourni
        avec l'application ; le bouton « Réinitialiser les règles par défaut » les recrée telles quelles, sans
        toucher à vos propres règles.
        {% if ai_module_enabled %}
            La règle « IA », toujours en dernier, demande à l'intelligence artificielle de choisir une catégorie
            existante pour chaque mouvement qu'aucune autre règle n'a su classer (ou de proposer une nouvelle
            catégorie) — désactivée par défaut, elle ne peut être ni déplacée ni supprimée, seulement activée/désactivée.
            Activer cette règle génère davantage de requêtes vers le fournisseur IA (une par mouvement non classé
            par les autres règles) et peut donc engendrer des coûts supplémentaires.
        {% endif %}
    </p>

    <div class="d-flex flex-column gap-2 mb-4" id="rules-list">
        {% for rule in rules %}
            <div class="border rounded-3 p-2 d-flex align-items-center gap-2 {{ rule.isSystem ? 'bg-body-secondary bg-opacity-25' : '' }} rule-item" data-id="{{ rule.id }}" draggable="true">
                <i class="bi bi-grip-vertical text-body-secondary drag-handle d-none d-lg-inline" style="cursor: grab;"></i>
                {# Touch reorder: move up/down buttons below lg #}
                <span class="d-lg-none d-inline-flex flex-column gap-0 flex-shrink-0 rule-move-btns">
                    <button type="button" class="btn btn-sm btn-link text-body-secondary p-0 rule-move-up" aria-label="Monter"{% if loop.first %} disabled{% endif %}><i class="bi bi-chevron-up"></i></button>
                    <button type="button" class="btn btn-sm btn-link text-body-secondary p-0 rule-move-down" aria-label="Descendre"{% if loop.last %} disabled{% endif %}><i class="bi bi-chevron-down"></i></button>
                </span>
                <div class="flex-grow-1">
                    {% if rule.isSystem %}<span class="badge text-bg-secondary"><i class="bi bi-gear-fill me-1"></i>Automatique</span>{% endif %}
                    {% if rule.isDefault %}<span class="badge text-bg-light border">Par défaut</span>{% endif %}
                    {% if rule.keywordPattern %}<span class="badge text-bg-light">Mot-clé : {{ rule.keywordPattern }}</span>{% endif %}
                    {% if rule.counterpartyAccountPattern %}<span class="badge text-bg-light">Contrepartie : {{ rule.counterpartyAccountPattern }}</span>{% endif %}
                    {% if rule.amountRange %}<span class="badge text-bg-light">Montant : {{ rule.amountRange }}</span>{% endif %}
                    <i class="bi bi-arrow-right mx-1"></i>
                    <span>{{ categories_by_id[rule.categoryId] is defined ? categories_by_id[rule.categoryId].name : '—' }}</span>
                </div>
                {% if not rule.isSystem %}
                    <button type="button" class="btn btn-sm btn-outline-secondary edit-rule-btn"
                            data-id="{{ rule.id }}"
                            data-keyword-pattern="{{ rule.keywordPattern }}"
                            data-counterparty-account-pattern="{{ rule.counterpartyAccountPattern }}"
                            data-amount-range="{{ rule.amountRange }}"
                            data-category-id="{{ rule.categoryId }}"
                            title="Modifier" aria-label="Modifier"><i class="bi bi-pencil"></i></button>
                    <button type="button" class="btn btn-sm {{ rule.isActive ? 'btn-outline-success' : 'btn-outline-secondary' }} toggle-rule-btn"
                            data-id="{{ rule.id }}" data-active="{{ rule.isActive ? '1' : '0' }}"
                            title="{{ rule.isActive ? 'Actif — cliquer pour désactiver' : 'Inactif — cliquer pour activer' }}"
                            aria-label="{{ rule.isActive ? 'Actif — cliquer pour désactiver' : 'Inactif — cliquer pour activer' }}">
                        <i class="bi {{ rule.isActive ? 'bi-toggle-on' : 'bi-toggle-off' }}"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger delete-rule-btn" data-id="{{ rule.id }}" title="Supprimer" aria-label="Supprimer"><i class="bi bi-trash"></i></button>
                {% endif %}
            </div>
        {% else %}
            <p class="text-body-secondary fst-italic mb-0">Aucune règle configurée.</p>
        {% endfor %}
    </div>

    {% if ai_module_enabled %}
        <div class="border rounded-3 p-2 d-flex align-items-center gap-2 mb-4 bg-body-secondary bg-opacity-25">
            <i class="bi bi-grip-vertical text-body-secondary" style="visibility: hidden;"></i>
            <div class="flex-grow-1">
                <span class="badge text-bg-info"><i class="bi bi-robot me-1"></i>IA</span>
                <span>Choisit une catégorie existante avec l'IA, ou propose une nouvelle catégorie — toujours évaluée en dernier. Activer cette règle génère davantage de requêtes IA et peut donc engendrer des coûts.</span>
            </div>
            <button type="button" class="btn btn-sm {{ ai_rule_enabled ? 'btn-outline-success' : 'btn-outline-secondary' }}" id="toggle-ai-rule-btn"
                    data-active="{{ ai_rule_enabled ? '1' : '0' }}"
                    title="{{ ai_rule_enabled ? 'Actif — cliquer pour désactiver' : 'Inactif — cliquer pour activer' }}">
                <i class="bi {{ ai_rule_enabled ? 'bi-toggle-on' : 'bi-toggle-off' }}"></i>
            </button>
        </div>
    {% endif %}

    <div class="modal fade" id="rule-modal" tabindex="-1">
        <div class="modal-dialog modal-fullscreen-sm-down modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="rule-form-title">Nouvelle règle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="rule-form">
                    <div class="modal-body">
                        <input type="hidden" id="rule-id" value="">
                        <div class="row g-2">
                            <div class="col-12 col-md-6">
                                <label class="form-label small" for="rule-keyword-pattern">Mot-clé / expression régulière (libellé)</label>
                                <input type="text" class="form-control form-control-sm" id="rule-keyword-pattern" placeholder="ex. delhaize ou ^VIR.*DUPONT$">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label small" for="rule-counterparty-account-pattern">Compte contrepartie</label>
                                <input type="text" class="form-control form-control-sm" id="rule-counterparty-account-pattern" placeholder="ex. BE71 0000">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label small" for="rule-amount-range">Montant</label>
                                <input type="text" class="form-control form-control-sm" id="rule-amount-range" placeholder="ex. >100 ou 10-50">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label small" for="rule-category">Catégorie</label>
                                <select class="form-select form-select-sm" id="rule-category">
                                    {% for category in active_categories %}
                                        <option value="{{ category.id }}">{{ category.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="button" class="btn btn-sm btn-outline-primary" id="test-rule-btn">Tester</button>
                                <div class="mt-2 small" id="test-rule-result"></div>
                            </div>
                        </div>
                        <div class="text-danger small mt-2 d-none" id="rule-form-error"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-sm btn-primary">Enregistrer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}">
const csrf = () => document.querySelector('meta[name="csrf-token"]')?.content;

// --- Categories ---
const categoryModalEl = document.getElementById('category-modal');
const categoryModal = window.bootstrap ? new window.bootstrap.Modal(categoryModalEl) : null;
const categoryErrorBox = document.getElementById('category-form-error');

function showCategoryModal(title) {
    document.getElementById('category-form-title').textContent = title;
    categoryErrorBox.classList.add('d-none');
    categoryModal ? categoryModal.show() : categoryModalEl.classList.add('show');
}

document.getElementById('new-category-btn').addEventListener('click', () => {
    document.getElementById('category-id').value = '';
    document.getElementById('category-name').value = '';
    document.getElementById('category-description').value = '';
    showCategoryModal('Nouvelle catégorie');
});

document.querySelectorAll('.edit-category-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('category-id').value = btn.dataset.id;
        document.getElementById('category-name').value = btn.dataset.name;
        document.getElementById('category-description').value = btn.dataset.description;
        showCategoryModal('Modifier la catégorie');
    });
});

document.querySelectorAll('.category-suggestion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('category-name').value = btn.dataset.name;
    });
});

document.getElementById('category-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('category-id').value;
    const payload = {
        action: id ? 'update' : 'create',
        name: document.getElementById('category-name').value,
        description: document.getElementById('category-description').value,
        _csrf_token: csrf()
    };
    if (id) payload.id = parseInt(id, 10);

    const res = await fetch('/config/finance/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        categoryErrorBox.textContent = data.error;
        categoryErrorBox.classList.remove('d-none');
    }
});

async function postCategoryAction(action, id) {
    const res = await fetch('/config/finance/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: action, id: id, _csrf_token: csrf() })
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        alert(data.error);
    }
}

document.querySelectorAll('.toggle-category-btn').forEach(btn => {
    btn.addEventListener('click', () => postCategoryAction(btn.dataset.active === '1' ? 'deactivate' : 'activate', parseInt(btn.dataset.id, 10)));
});

document.querySelectorAll('.delete-category-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        if (confirm('Supprimer cette catégorie ?')) {
            postCategoryAction('delete', parseInt(btn.dataset.id, 10));
        }
    });
});

document.getElementById('reset-default-categories-btn').addEventListener('click', async () => {
    if (!confirm('Recréer les catégories par défaut qui auraient été supprimées ? Les catégories existantes ne sont pas modifiées.')) {
        return;
    }
    const res = await fetch('/config/finance/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reset_defaults', _csrf_token: csrf() })
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        alert(data.error);
    }
});

// --- Categorization rules ---
const ruleModalEl = document.getElementById('rule-modal');
const ruleModal = window.bootstrap ? new window.bootstrap.Modal(ruleModalEl) : null;
const ruleErrorBox = document.getElementById('rule-form-error');

function showRuleModal(title) {
    document.getElementById('rule-form-title').textContent = title;
    ruleErrorBox.classList.add('d-none');
    ruleModal ? ruleModal.show() : ruleModalEl.classList.add('show');
}

document.getElementById('new-rule-btn').addEventListener('click', () => {
    document.getElementById('rule-form').reset();
    document.getElementById('rule-id').value = '';
    document.getElementById('test-rule-result').textContent = '';
    showRuleModal('Nouvelle règle');
});

document.getElementById('reset-default-rules-btn').addEventListener('click', async () => {
    if (!confirm("Réinitialiser les règles par défaut ? Toute modification apportée aux règles marquées « Par défaut » sera perdue. Vos propres règles ne seront pas touchées.")) {
        return;
    }
    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reset_defaults', _csrf_token: csrf() })
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        alert(data.error);
    }
});

const runRulesBtn = document.getElementById('run-rules-btn');
const runRulesStatus = document.getElementById('run-rules-status');
let runRulesPollTimer = null;

function setRunRulesRunning(running) {
    runRulesBtn.disabled = running;
    runRulesStatus.classList.toggle('d-none', !running);
}

async function pollRunRulesStatus() {
    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'run_status', _csrf_token: csrf() })
    });
    const data = await res.json();
    if (!data.success) {
        return;
    }

    setRunRulesRunning(data.running);

    if (data.running) {
        runRulesPollTimer = setTimeout(pollRunRulesStatus, 3000);
        return;
    }

    if (runRulesPollTimer !== null) {
        // Only true right after a run just completed (not on the initial
        // page-load check) — reload then, to reflect any newly-created
        // "nouvelle catégorie" suggestions and keep the movements page's
        // own numbers in sync next time it's opened.
        clearTimeout(runRulesPollTimer);
        runRulesPollTimer = null;
        if (data.last_result) {
            alert(
                data.last_result.categorized_by_rules + ' mouvement(s) catégorisé(s) par les règles, '
                + data.last_result.categorized_by_ai + ' par l\'IA, '
                + data.last_result.still_uncategorized + ' toujours non catégorisé(s).'
            );
        }
    }
}

document.getElementById('run-rules-btn').addEventListener('click', async () => {
    if (!confirm("Appliquer les règles de catégorisation à tous les mouvements non catégorisés ? Cette opération se déroule en arrière-plan.")) {
        return;
    }

    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'run_on_uncategorized', _csrf_token: csrf() })
    });
    const data = await res.json();

    if (data.success) {
        setRunRulesRunning(true);
        runRulesPollTimer = setTimeout(pollRunRulesStatus, 3000);
    } else {
        alert(data.error);
    }
});

// Reflect an already-in-progress run on page load (e.g. the admin
// navigated away and back while it was still running).
(async () => {
    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'run_status', _csrf_token: csrf() })
    });
    const data = await res.json();
    if (data.success && data.running) {
        setRunRulesRunning(true);
        runRulesPollTimer = setTimeout(pollRunRulesStatus, 3000);
    }
})();

document.querySelectorAll('.edit-rule-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('rule-id').value = btn.dataset.id;
        document.getElementById('rule-keyword-pattern').value = btn.dataset.keywordPattern;
        document.getElementById('rule-counterparty-account-pattern').value = btn.dataset.counterpartyAccountPattern;
        document.getElementById('rule-amount-range').value = btn.dataset.amountRange;
        document.getElementById('rule-category').value = btn.dataset.categoryId;
        document.getElementById('test-rule-result').textContent = '';
        showRuleModal('Modifier la règle');
    });
});

function ruleConditionsPayload() {
    return {
        keyword_pattern: document.getElementById('rule-keyword-pattern').value,
        counterparty_account_pattern: document.getElementById('rule-counterparty-account-pattern').value,
        amount_range: document.getElementById('rule-amount-range').value
    };
}

document.getElementById('test-rule-btn').addEventListener('click', async () => {
    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.assign({ action: 'test', _csrf_token: csrf() }, ruleConditionsPayload()))
    });
    const data = await res.json();
    const resultBox = document.getElementById('test-rule-result');
    if (data.success) {
        resultBox.textContent = data.count + ' mouvement(s) existant(s) correspondent.';
    } else {
        resultBox.textContent = data.error;
    }
});

document.getElementById('rule-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('rule-id').value;
    const payload = Object.assign({
        action: id ? 'update' : 'create',
        category_id: parseInt(document.getElementById('rule-category').value, 10),
        _csrf_token: csrf()
    }, ruleConditionsPayload());
    if (id) payload.id = parseInt(id, 10);

    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        ruleErrorBox.textContent = data.error;
        ruleErrorBox.classList.remove('d-none');
    }
});

async function postRuleAction(action, extra) {
    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.assign({ action: action, _csrf_token: csrf() }, extra))
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        alert(data.error);
    }
}

document.querySelectorAll('.toggle-rule-btn').forEach(btn => {
    btn.addEventListener('click', () => postRuleAction(btn.dataset.active === '1' ? 'deactivate' : 'activate', { id: parseInt(btn.dataset.id, 10) }));
});

document.getElementById('toggle-ai-rule-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    const res = await fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'set_ai_enabled', enabled: btn.dataset.active !== '1', _csrf_token: csrf() })
    });
    const data = await res.json();
    if (data.success) {
        window.location.reload();
    } else {
        alert(data.error);
    }
});

document.querySelectorAll('.delete-rule-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        if (confirm('Supprimer cette règle ?')) {
            postRuleAction('delete', { id: parseInt(btn.dataset.id, 10) });
        }
    });
});

// --- Drag-and-drop reordering ---
const rulesList = document.getElementById('rules-list');
let draggedRow = null;

rulesList.querySelectorAll('div[data-id]').forEach(row => {
    row.addEventListener('dragstart', () => {
        draggedRow = row;
        row.classList.add('opacity-50');
    });
    row.addEventListener('dragend', () => {
        row.classList.remove('opacity-50');
        draggedRow = null;
    });
    row.addEventListener('dragover', (e) => {
        e.preventDefault();
        if (!draggedRow || draggedRow === row) {
            return;
        }
        const rect = row.getBoundingClientRect();
        const before = (e.clientY - rect.top) < rect.height / 2;
        row.parentNode.insertBefore(draggedRow, before ? row : row.nextSibling);
    });
    row.addEventListener('drop', async (e) => {
        e.preventDefault();
        const ids = Array.from(rulesList.querySelectorAll('div[data-id]')).map(r => parseInt(r.dataset.id, 10));
        const res = await fetch('/config/finance/rules', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'reorder', ordered_ids: ids, _csrf_token: csrf() })
        });
        const data = await res.json();
        if (!data.success) {
            alert(data.error);
            window.location.reload();
        }
        // On success the list is already visually reordered by the
        // drag-and-drop handlers above — no reload needed.
    });
});

// --- Move up/down (touch-friendly alternative to drag-and-drop for rules) ---
function persistRuleOrder() {
    const ids = Array.from(rulesList.querySelectorAll('div[data-id]')).map(r => parseInt(r.dataset.id, 10));
    fetch('/config/finance/rules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reorder', ordered_ids: ids, _csrf_token: csrf() })
    }).then(r => r.json()).then(d => { if (!d.success) alert(d.error); });
}
function updateRuleMoveButtons() {
    const items = Array.from(rulesList.querySelectorAll('.rule-item'));
    items.forEach((item, i) => {
        const up = item.querySelector('.rule-move-up');
        const down = item.querySelector('.rule-move-down');
        if (up) up.disabled = (i === 0);
        if (down) down.disabled = (i === items.length - 1);
    });
}
rulesList.querySelectorAll('.rule-move-up').forEach(btn => {
    btn.addEventListener('click', () => {
        const item = btn.closest('.rule-item');
        const prev = item.previousElementSibling;
        if (prev && prev.classList.contains('rule-item')) {
            rulesList.insertBefore(item, prev);
            persistRuleOrder();
            updateRuleMoveButtons();
        }
    });
});
rulesList.querySelectorAll('.rule-move-down').forEach(btn => {
    btn.addEventListener('click', () => {
        const item = btn.closest('.rule-item');
        const next = item.nextElementSibling;
        if (next && next.classList.contains('rule-item')) {
            rulesList.insertBefore(next, item);
            persistRuleOrder();
            updateRuleMoveButtons();
        }
    });
});
</script>
{% endblock %}
