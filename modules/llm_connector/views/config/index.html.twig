{% extends "base.html.twig" %}

{% block title %}Intelligence artificielle — {{ site_name }}{% endblock %}

{% block content %}
<h1 class="h3 mb-4">Intelligence artificielle</h1>

{# Module description #}
<div class="card mb-4">
    <div class="card-body">
        <h2 class="h6 mb-3">À quoi sert ce module ?</h2>
        <p class="mb-2">
            Ce module connecte ScoutMagic à un fournisseur d'intelligence artificielle générative.
            Il permet aux autres modules d'exploiter l'IA pour des tâches telles que :
        </p>
        <ul class="mb-3">
            <li>Analyser automatiquement les factures et extraire les montants, dates et fournisseurs</li>
            <li>Catégoriser les dépenses dans les bonnes rubriques comptables</li>
            <li>Générer des résumés ou des suggestions à partir de documents</li>
        </ul>
        <div class="alert alert-warning mb-0">
            <strong>Données personnelles :</strong> lorsque ce module est actif, certaines données
            (contenu de factures, noms, montants) sont transmises au fournisseur IA sélectionné
            pour traitement. Ces données quittent les serveurs de ScoutMagic.
            Consultez la politique de confidentialité du fournisseur choisi ci-dessous avant d'activer ce module.
        </div>
    </div>
</div>

{# Status summary #}
<div class="card mb-4" data-summary>
    <div class="card-body">
        <h2 class="h6 mb-3">Résumé</h2>
        <div class="row g-3">
            <div class="col-12 col-md-4">
                <span class="text-body-secondary small d-block">Statut</span>
                {% if active_provider and (cheap_model or capable_model) %}
                    <span class="badge bg-success">Actif</span>
                {% else %}
                    <span class="badge bg-secondary">Non configuré</span>
                {% endif %}
            </div>
            <div class="col-12 col-md-8" data-provider>
                <span class="text-body-secondary small d-block">Fournisseur</span>
                <strong>{{ active_provider ? active_provider.name : '—' }}</strong>
            </div>
        </div>
        <div class="row g-3 mt-2">
            <div class="col-12 col-md-4" data-cheap>
                <span class="text-body-secondary small d-block">Modèle économique</span>
                <strong>{{ cheap_model ? cheap_model.display_name : '—' }}</strong>
            </div>
            <div class="col-12 col-md-4" data-capable>
                <span class="text-body-secondary small d-block">Modèle performant</span>
                <strong>{{ capable_model ? capable_model.display_name : '—' }}</strong>
            </div>
            <div class="col-12 col-md-4" data-ocr>
                <span class="text-body-secondary small d-block">Modèle OCR</span>
                <strong>{{ ocr_model ? ocr_model.display_name : (cheap_model ? cheap_model.display_name ~ ' (fallback)' : '—') }}</strong>
            </div>
        </div>
    </div>
</div>

{# Provider form #}
<div class="card mb-4">
    <div class="card-body">
        <h2 class="h6 mb-3">Fournisseur</h2>
        <form id="provider-form" class="row g-3">
            <input type="hidden" id="provider-id" value="">
            <input type="hidden" id="provider-name" value="">
            <input type="hidden" id="provider-endpoint" value="">
            <input type="hidden" id="provider-has-key" value="">

            <div class="col-md-6">
                <label for="provider-driver" class="form-label">Fournisseur IA</label>
                <select class="form-select" id="provider-driver" required>
                    {% for driver in available_drivers %}
                        {% set saved_provider = providers_by_driver[driver.id] ?? null %}
                        <option value="{{ driver.id }}"
                                data-endpoint="{{ driver.default_endpoint }}"
                                data-label="{{ driver.label }}"
                                data-provider-id="{{ saved_provider ? saved_provider.id : '' }}"
                                data-has-key="{{ saved_provider ? '1' : '0' }}"
                                {{ active_provider and active_provider.driver == driver.id ? 'selected' : '' }}>
                            {{ driver.label }}{{ saved_provider ? ' (✓)' : '' }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Driver-specific help — Anthropic #}
            <div class="col-12" id="driver-help-anthropic">
                <div class="alert alert-light border mb-0">
                    <strong>Comment obtenir votre clé API Anthropic :</strong>
                    <ol class="mb-2 mt-2">
                        <li>Connectez-vous ou créez un compte sur <a href="https://console.anthropic.com/" target="_blank" rel="noopener">console.anthropic.com</a>.</li>
                        <li>Accédez à la page <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener">Settings &rarr; API Keys</a>.</li>
                        <li>Cliquez sur « Create Key », donnez-lui un nom (ex. « ScoutMagic ») et copiez la clé générée.</li>
                        <li>Collez-la ci-dessous. La clé est chiffrée avant d'être stockée en base de données.</li>
                    </ol>
                    <p class="mb-1 small"><strong>Localisation des serveurs :</strong> États-Unis (hors Union européenne). Les données sont stockées aux USA.</p>
                    <p class="mb-0 small">
                        <a href="https://www.anthropic.com/legal/privacy" target="_blank" rel="noopener">Politique de confidentialité Anthropic</a>
                        ·
                        <a href="https://www.anthropic.com/legal/commercial-terms" target="_blank" rel="noopener">Conditions commerciales</a>
                    </p>
                </div>
            </div>

            {# Driver-specific help — Mistral #}
            <div class="col-12" id="driver-help-mistral">
                <div class="alert alert-light border mb-0">
                    <strong>Comment obtenir votre clé API Mistral :</strong>
                    <ol class="mb-2 mt-2">
                        <li>Connectez-vous ou créez un compte sur <a href="https://console.mistral.ai/" target="_blank" rel="noopener">console.mistral.ai</a>.</li>
                        <li>Accédez à la page <a href="https://console.mistral.ai/api-keys" target="_blank" rel="noopener">API Keys</a>.</li>
                        <li>Créez une clé, copiez-la et collez-la ci-dessous.</li>
                    </ol>
                    <p class="mb-1 small"><strong>Localisation des serveurs :</strong> Union européenne (France). Société française, conforme au RGPD.</p>
                    <p class="mb-0 small">
                        <a href="https://legal.mistral.ai/terms/privacy-policy" target="_blank" rel="noopener">Politique de confidentialité Mistral AI</a>
                        ·
                        <a href="https://legal.mistral.ai/terms/data-processing-addendum" target="_blank" rel="noopener">Accord de traitement des données</a>
                    </p>
                </div>
            </div>

            {# Driver-specific help — Scaleway #}
            <div class="col-12" id="driver-help-scaleway">
                <div class="alert alert-light border mb-0">
                    <strong>Comment obtenir votre clé API Scaleway :</strong>
                    <ol class="mb-2 mt-2">
                        <li>Connectez-vous ou créez un compte sur <a href="https://console.scaleway.com/" target="_blank" rel="noopener">console.scaleway.com</a>.</li>
                        <li>Accédez à <a href="https://console.scaleway.com/iam/api-keys" target="_blank" rel="noopener">IAM &rarr; API Keys</a>.</li>
                        <li>Créez une clé API avec accès au produit « Generative APIs », copiez le <em>Secret Key</em>.</li>
                        <li>Collez-le ci-dessous.</li>
                    </ol>
                    <p class="mb-1 small"><strong>Localisation des serveurs :</strong> Union européenne (France, Pays-Bas). Société française, conforme au RGPD.</p>
                    <p class="mb-0 small">
                        <a href="https://www.scaleway.com/en/privacy-policy/" target="_blank" rel="noopener">Politique de confidentialité Scaleway</a>
                        ·
                        <a href="https://www.scaleway.com/en/contracts/" target="_blank" rel="noopener">Conditions générales</a>
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <label for="provider-api-key" class="form-label">Clé API</label>
                <div class="d-flex flex-column flex-sm-row gap-2">
                    <input type="password" class="form-control flex-grow-1" id="provider-api-key" placeholder="">
                    <button type="submit" class="btn btn-primary text-nowrap">Enregistrer</button>
                </div>
                <div class="form-text" id="api-key-hint"></div>
            </div>
        </form>
        <div id="provider-message" class="mt-3" style="display:none;"></div>
    </div>
</div>

{# Models section #}
<div class="card mb-4">
    <div class="card-body">
        <h2 class="h6 mb-3">Modèles disponibles</h2>
        <div id="models-container">
            {# Populated dynamically via JavaScript based on selected driver #}
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}">
const csrf = () => document.querySelector('meta[name="csrf-token"]')?.content;

// Models data from server
const modelsByDriver = {{ models_by_driver|json_encode|raw }};

// Auto-fill hidden name/endpoint, show/hide driver help, update models list
function updateDriverInfo() {
    const select = document.getElementById('provider-driver');
    const option = select?.selectedOptions[0];
    if (!option) return;

    const driverValue = select.value;
    const providerId = option.dataset.providerId || '';
    const hasKey = option.dataset.hasKey === '1';

    // Update hidden fields
    document.getElementById('provider-id').value = providerId;
    document.getElementById('provider-name').value = option.dataset.label || option.textContent.trim();
    document.getElementById('provider-endpoint').value = option.dataset.endpoint || '';
    document.getElementById('provider-has-key').value = hasKey ? '1' : '0';

    // Update API key hint
    const hintEl = document.getElementById('api-key-hint');
    if (hasKey) {
        hintEl.textContent = 'Laisser vide pour conserver la clé actuelle.';
        document.getElementById('provider-api-key').placeholder = '••••••••';
    } else {
        hintEl.textContent = '';
        document.getElementById('provider-api-key').placeholder = '';
    }

    // Show/hide driver-specific help
    document.querySelectorAll('[id^="driver-help-"]').forEach(el => {
        el.style.display = el.id === 'driver-help-' + driverValue ? '' : 'none';
    });

    // Update models list
    updateModelsList(driverValue);
}

function updateModelsList(driver) {
    const container = document.getElementById('models-container');
    const models = modelsByDriver[driver] || [];

    if (models.length === 0) {
        container.innerHTML = '<p class="text-body-secondary mb-0">Aucun modèle découvert. Enregistrez une clé API pour interroger l\'API du fournisseur.</p>';
        return;
    }

    let html = '<p class="text-body-secondary small mb-3">Les modèles économique, performant et OCR sont sélectionnés automatiquement parmi les modèles disponibles du fournisseur.</p>';
    html += '<div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>Modèle</th><th>Rôle</th></tr></thead><tbody>';

    models.forEach(model => {
        html += '<tr><td>' + escapeHtml(model.display_name) + '<span class="text-body-secondary small d-block"><code>' + escapeHtml(model.model_id) + '</code></span></td><td>';
        
        if (model.is_tier_cheap) html += '<span class="badge bg-info text-dark">Économique</span> ';
        if (model.is_tier_capable) html += '<span class="badge bg-primary">Performant</span> ';
        if (model.is_tier_ocr) html += '<span class="badge bg-success">OCR</span> ';
        if (!model.is_tier_cheap && !model.is_tier_capable && !model.is_tier_ocr) {
            html += '<span class="text-body-secondary">—</span>';
        }
        
        html += '</td></tr>';
    });

    html += '</tbody></table></div>';
    container.innerHTML = html;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

updateDriverInfo();

document.getElementById('provider-driver')?.addEventListener('change', () => {
    updateDriverInfo();
    // Auto-test if provider has saved key, and activate this provider
    const hasKey = document.getElementById('provider-has-key').value === '1';
    const providerId = document.getElementById('provider-id').value;
    if (hasKey && providerId) {
        testConnection(providerId, true);
    }
});

// Provider form — save then auto-test connection
document.getElementById('provider-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msgEl = document.getElementById('provider-message');
    msgEl.style.display = 'block';
    msgEl.innerHTML = '<div class="alert alert-info mb-0">Enregistrement en cours…</div>';

    const body = {
        id: document.getElementById('provider-id').value || null,
        name: document.getElementById('provider-name').value,
        driver: document.getElementById('provider-driver').value,
        api_endpoint: document.getElementById('provider-endpoint').value,
        api_key: document.getElementById('provider-api-key').value,
        _csrf_token: csrf()
    };

    const res = await fetch('/config/llm/providers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    });
    const data = await res.json();
    if (!data.success) {
        msgEl.innerHTML = '<div class="alert alert-danger mb-0">' + data.error + '</div>';
        return;
    }

    // Save succeeded — now test connection
    const providerId = data.provider_id;
    document.getElementById('provider-id').value = providerId;
    msgEl.innerHTML = '<div class="alert alert-info mb-0">Test de connexion en cours…</div>';

    await testConnection(providerId);
});

// Test connection function (also used on dropdown change)
async function testConnection(providerId, shouldActivate = false) {
    const msgEl = document.getElementById('provider-message');
    if (!providerId) {
        providerId = document.getElementById('provider-id').value;
    }
    if (!providerId) return;

    msgEl.style.display = 'block';
    msgEl.innerHTML = '<div class="alert alert-info mb-0">Test de connexion en cours…</div>';

    const res = await fetch('/config/llm/providers/' + providerId + '/test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ _csrf_token: csrf() })
    });
    const data = await res.json();
    if (data.success) {
        // If shouldActivate is true (from dropdown change), save provider as active
        if (shouldActivate) {
            const saveRes = await fetch('/config/llm/providers', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: providerId,
                    name: document.getElementById('provider-name').value,
                    driver: document.getElementById('provider-driver').value,
                    api_endpoint: document.getElementById('provider-endpoint').value,
                    api_key: '',  // Empty = keep existing key
                    _csrf_token: csrf()
                })
            });
            const saveData = await saveRes.json();
            if (!saveData.success) {
                msgEl.innerHTML = '<div class="alert alert-warning mb-0">Modèles rafraîchis mais échec de l\'activation.</div>';
                return;
            }
        }
        
        updateSummary(data);
        msgEl.innerHTML = '<div class="alert alert-success mb-0">Connexion réussie — ' + data.message.replace('Connexion réussie — ', '') + '</div>';
        setTimeout(() => window.location.reload(), 800);
    } else {
        msgEl.innerHTML = '<div class="alert alert-danger mb-0">' + data.error + '</div>';
    }
}

function updateSummary(data) {
    const summaryCard = document.querySelector('[data-summary]');
    if (!summaryCard) return;

    const badge = summaryCard.querySelector('.badge');
    if (badge) {
        badge.className = 'badge bg-success';
        badge.textContent = 'Actif';
    }

    const providerStrong = summaryCard.querySelector('[data-provider] strong');
    if (providerStrong && data.provider_name) {
        providerStrong.textContent = data.provider_name;
    }

    const cheapStrong = summaryCard.querySelector('[data-cheap] strong');
    if (cheapStrong) {
        cheapStrong.textContent = data.cheap_model || '—';
    }

    const capableStrong = summaryCard.querySelector('[data-capable] strong');
    if (capableStrong) {
        capableStrong.textContent = data.capable_model || '—';
    }

    const ocrStrong = summaryCard.querySelector('[data-ocr] strong');
    if (ocrStrong) {
        const ocrText = data.ocr_model || '—';
        ocrStrong.textContent = data.ocr_fallback ? ocrText + ' (fallback)' : ocrText;
    }
}


</script>
{% endblock %}
